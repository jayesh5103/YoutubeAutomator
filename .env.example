# ── LLM Provider ─────────────────────────────────────────────────────
# Select the LLM provider (groq, gemini, or openai)
LLM_PROVIDER=groq

# Groq API Key — FREE, 14,400 requests/day
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API Key (if using gemini provider)
# Supports multiple keys separated by commas for rate-limit rotation
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (if using openai provider)
OPENAI_API_KEY=your_openai_api_key_here

# ── Video Assets ─────────────────────────────────────────────────────
# Pexels API Key for background videos
# Supports multiple keys separated by commas for rate-limit rotation
PEXELS_API_KEY=your_pexels_api_key_here

# ── Video Configuration ──────────────────────────────────────────────
# 'shorts' for <60s vertical videos, 'long' for horizontal standard videos
VIDEO_FORMAT=shorts

# Maximum videos to generate per day (preserves API quota)
DAILY_VIDEO_LIMIT=6
